# ─── Supabase ────────────────────────────────────────────────────────────────
# 1. Gehe zu https://supabase.com → "New project" erstellen
# 2. Unter Project Settings → API findest du die folgenden Werte:

# Produktion (Netlify u. a.): diese beiden — unter „Environment variables“ eintragen (reichen für API routes)
SUPABASE_URL=https://DEIN-PROJEKT.supabase.co
SUPABASE_ANON_KEY=DEIN-ANON-KEY

# Optional lokal / gleiche Werte wie oben (weiterhin unterstützt)
NEXT_PUBLIC_SUPABASE_URL=https://DEIN-PROJEKT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=DEIN-ANON-KEY

# 3. Führe das SQL aus supabase/migrations/001_shared_profiles.sql
#    im Supabase SQL-Editor aus.

# ─── App-URL (für serverseitige Profil-Links) ─────────────────────────────────
# In Netlify unter Site configuration → Environment variables eintragen:
NEXT_PUBLIC_APP_URL=https://DEINE-DOMAIN.netlify.app
